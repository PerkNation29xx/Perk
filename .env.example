PROJECT_NAME=PerkNation Backend
API_V1_PREFIX=/v1
# Local (no Docker) default:
DATABASE_URL=sqlite:///./perknation.db

# Docker/Postgres example:
# DATABASE_URL=postgresql+psycopg://perknation:perknation@db:5432/perknation

# Supabase/Postgres (recommended): use discrete vars so passwords with special
# characters don't need URL-encoding.
# DATABASE_HOST=db.wsfzhygpzkuvijinjlgx.supabase.co
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USER=postgres
# DATABASE_PASSWORD=replace-with-your-db-password
# DATABASE_SSLMODE=require
# DATABASE_FORCE_IPV4=true

# Supabase Auth (optional): allow the backend to accept Supabase access tokens.
# SUPABASE_URL=https://wsfzhygpzkuvijinjlgx.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_cRkjkn0kpS7b36zJa-moTQ_zc6alUHs
# Auth redirect URLs used in Supabase email links (verify/reset).
PUBLIC_WEB_BASE_URL=https://perknation.net
SUPABASE_EMAIL_REDIRECT_PATH=/login
SUPABASE_PASSWORD_RESET_REDIRECT_PATH=/reset-password
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
SEED_DEFAULT_DATA=true
EMAIL_VERIFICATION_CODE_TTL_MINUTES=30
# For local dev only: return the verification code in API responses.
DEV_EXPOSE_EMAIL_VERIFICATION_CODE=true

# Public website forms: mirror each submission to a local backup database.
FORMS_BACKUP_ENABLED=true
FORMS_BACKUP_DATABASE_URL=sqlite:///./perknation_forms_backup.db
WALLET_PASS_TYPE_IDENTIFIER=pass.com.example.perknation
WALLET_TEAM_IDENTIFIER=YOURTEAMID
WALLET_ORGANIZATION_NAME=PerkNation
WALLET_PASS_SERVICE_URL=
WALLET_SIGNER_CERTIFICATE_PATH=/absolute/path/to/pass.pem
WALLET_SIGNER_KEY_PATH=/absolute/path/to/pass.key.pem
WALLET_WWDR_CERTIFICATE_PATH=/absolute/path/to/AppleWWDRCAG4.pem
# Hosted environments can use PEM contents instead of file paths.
WALLET_SIGNER_CERTIFICATE_PEM=
WALLET_SIGNER_KEY_PEM=
WALLET_WWDR_CERTIFICATE_PEM=

# Contact form notifications (optional).
CONTACT_EMAIL_FORWARDING_ENABLED=true
CONTACT_FORM_NOTIFY_EMAIL=perknation29@icloud.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@perknation.net
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# AI assistant provider:
# - ollama: local model on this machine
# - openai: hosted/public model via OPENAI_API_KEY
AI_ENABLED=true
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_TEMPERATURE=0.2

# Hosted AI (used when AI_PROVIDER=openai).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_TEMPERATURE=0.2
