PROJECT_NAME=PerkNation Backend
API_V1_PREFIX=/v1

# Use your existing public Supabase Postgres (same values you already use locally).
# Preferred on Render: use Supabase pooler URL (IPv4-friendly). If set, it takes precedence.
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@<pooler-host>:6543/postgres?sslmode=require
DATABASE_URL=

# Alternative (discrete direct host vars):
DATABASE_HOST=db.wsfzhygpzkuvijinjlgx.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-your-supabase-db-password
DATABASE_SSLMODE=require
# Recommended on Render when direct DB host resolves to IPv6 and fails routing.
DATABASE_FORCE_IPV4=true

# Supabase Auth (same public project values).
SUPABASE_URL=https://wsfzhygpzkuvijinjlgx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_cRkjkn0kpS7b36zJa-moTQ_zc6alUHs
PUBLIC_WEB_BASE_URL=https://perknation.net
SUPABASE_EMAIL_REDIRECT_PATH=/login
SUPABASE_PASSWORD_RESET_REDIRECT_PATH=/reset-password

# App security
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Production flags
SEED_DEFAULT_DATA=false
DEV_EXPOSE_EMAIL_VERIFICATION_CODE=false

# Render has ephemeral disk; keep local backup file mirroring off in production.
FORMS_BACKUP_ENABLED=false
FORMS_BACKUP_DATABASE_URL=sqlite:///./perknation_forms_backup.db

# Contact form notifications (SMTP).
CONTACT_EMAIL_FORWARDING_ENABLED=true
CONTACT_FORM_NOTIFY_EMAIL=perknation29@icloud.com
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@perknation.net
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# AI provider for production/public app traffic.
AI_ENABLED=true
AI_PROVIDER=openai

# Hosted AI (OpenAI-compatible).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_TEMPERATURE=0.2

# Optional local model path (mainly for local dev).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_TEMPERATURE=0.2

# Apple Wallet pass signing.
# Provide either a separate pass service URL or local certificate paths.
WALLET_PASS_SERVICE_URL=
WALLET_PASS_TYPE_IDENTIFIER=pass.com.example.perknation
WALLET_TEAM_IDENTIFIER=YOURTEAMID
WALLET_ORGANIZATION_NAME=PerkNation
WALLET_SIGNER_CERTIFICATE_PATH=/etc/perknation/pass.pem
WALLET_SIGNER_KEY_PATH=/etc/perknation/pass.key.pem
WALLET_WWDR_CERTIFICATE_PATH=/etc/perknation/AppleWWDRCAG4.pem
# Hosted environments like Render can use PEM contents instead of file paths.
WALLET_SIGNER_CERTIFICATE_PEM=
WALLET_SIGNER_KEY_PEM=
WALLET_WWDR_CERTIFICATE_PEM=

# The HQ dedicated Apple Wallet pass signing (must be separate from PerkNation).
WALLET_HQ_PASS_TYPE_IDENTIFIER=pass.com.neonflux.thq
WALLET_HQ_TEAM_IDENTIFIER=PL9PGQKXUW
WALLET_HQ_ORGANIZATION_NAME=NEONFLUX LLC
WALLET_HQ_DESCRIPTION=The HQ
WALLET_HQ_SIGNER_CERTIFICATE_PATH=/etc/perknation/thq-pass.pem
WALLET_HQ_SIGNER_KEY_PATH=/etc/perknation/thq-pass.key.pem
WALLET_HQ_WWDR_CERTIFICATE_PATH=/etc/perknation/AppleWWDRCAG4.pem
WALLET_HQ_SIGNER_CERTIFICATE_PEM=
WALLET_HQ_SIGNER_KEY_PEM=
WALLET_HQ_WWDR_CERTIFICATE_PEM=
