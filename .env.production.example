PROJECT_NAME=PerkNation Backend
API_V1_PREFIX=/v1

# Use your existing public Supabase Postgres (same values you already use locally).
DATABASE_HOST=db.wsfzhygpzkuvijinjlgx.supabase.co
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-your-supabase-db-password
DATABASE_SSLMODE=require
# Recommended on Render when direct DB host resolves to IPv6 and fails routing.
DATABASE_FORCE_IPV4=true

# Supabase Auth (same public project values).
SUPABASE_URL=https://wsfzhygpzkuvijinjlgx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_cRkjkn0kpS7b36zJa-moTQ_zc6alUHs

# App security
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Production flags
SEED_DEFAULT_DATA=false
DEV_EXPOSE_EMAIL_VERIFICATION_CODE=false

# Render has ephemeral disk; keep local backup file mirroring off in production.
FORMS_BACKUP_ENABLED=false
FORMS_BACKUP_DATABASE_URL=sqlite:///./perknation_forms_backup.db

# Optional local LLM integration; disable by default in cloud.
AI_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_TEMPERATURE=0.2
